# Reranker 配置（硅基流动）
RERANKER_API_KEY=sk-xxx
RERANKER_BASE_URL=https://api.siliconflow.cn/v1
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# MinerU 配置
MINERU_API_TOKEN=xxx
MINERU_BASE_URL=https://mineru.net/api/v4
